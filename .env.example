# Telegram bot — from @BotFather. Bot username: @NeuroSpicyCommanderBot
TELEGRAM_BOT_TOKEN=

# L'Oreal's Telegram chat ID — bot only responds to this user. Get from @userinfobot.
TELEGRAM_USER_ID=

# Anthropic API — console.anthropic.com
ANTHROPIC_API_KEY=

# Google Service Account JSON, full single-line string (escape newlines in private_key as \\n)
# Create at: console.cloud.google.com → IAM → Service Accounts → New → grant "Editor" on the sheet
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheet ID — from URL: docs.google.com/spreadsheets/d/{THIS_PART}/edit
GOOGLE_SHEET_ID=

# Optional: override timezone (default America/New_York)
TIMEZONE=America/New_York
