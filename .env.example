# Telegram bot — from @BotFather. Bot username: @NeuroSpicyCommanderBot
TELEGRAM_BOT_TOKEN=

# L'Oreal's Telegram chat ID — bot only responds to this user. Get from @userinfobot.
TELEGRAM_USER_ID=

# Anthropic API — console.anthropic.com
ANTHROPIC_API_KEY=

# Google OAuth — uses your personal Google account (not a service account)
# Get Client ID + Secret at: https://console.cloud.google.com/apis/credentials
# Make sure http://localhost:3000/oauth2callback is in the OAuth client's "Authorized redirect URIs"
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Get this by running locally: npm run oauth-bootstrap
# It opens a browser, you authorize once, the script prints the refresh token to paste here
GOOGLE_OAUTH_REFRESH_TOKEN=

# Google Sheet ID — from URL: docs.google.com/spreadsheets/d/{THIS_PART}/edit
GOOGLE_SHEET_ID=

# Optional: override timezone (default America/New_York)
TIMEZONE=America/New_York
